{
  "name": "dd-plugin",
  "version": "1.0.0",
  "description": "Autonomous domain-name finder — MCP server + multi-tool integrations (Claude Code, OpenCode, Cursor, Cline, Continue, Windsurf, VS Code Copilot, Zed, Goose)",
  "type": "module",
  "bin": {
    "dd-install": "./install.js"
  },
  "scripts": {
    "setup": "node install.js",
    "install:dry-run": "node install.js --dry-run",
    "install:all": "node install.js --all",
    "uninstall": "node install.js --uninstall",
    "postinstall": "npm install --prefix mcp-servers/derabia"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Amrwebdeveloper/dd-plugin.git"
  },
  "homepage": "https://github.com/Amrwebdeveloper/dd-plugin",
  "author": "Amr Web Developer <amrwebdeveloper@gmail.com>",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "opencode",
    "cursor",
    "cline",
    "continue.dev",
    "windsurf",
    "mcp",
    "domain",
    "whois",
    "derabia",
    "ai-tools"
  ]
}
