# =====================================================================
# Derabia MCP Server — Environment Variables
# =====================================================================
# Copy this file to `.env` (or export these in your shell / Claude Code
# settings) and fill in the values below.
#
# Both API keys are required. Get them at https://derabia.com
# =====================================================================

# WHOIS API — checks domain availability
DERABIA_WHOIS_API_KEY=your_whois_api_key_here

# Pricing API — predicts brand value via an ML model
DERABIA_PRICING_API_KEY=your_pricing_api_key_here

# --- Optional overrides ---
# Use these only if you need to point at a custom or staging endpoint.
# DERABIA_WHOIS_API_URL=https://api.derabia.com/whois
# DERABIA_PRICING_API_URL=https://api.derabia.com/pricing
